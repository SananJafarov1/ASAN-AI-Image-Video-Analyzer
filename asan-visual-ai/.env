# ============================================================
# ASAN Visual AI — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Google Gemini ---
GEMINI_API_KEY=AIzaSyA0ZKw8ttf4Nph1NRcVK1osSBLbocRZF78
GEMINI_MODEL=gemini-3.1-pro-preview

# --- PostgreSQL ---
DATABASE_URL=postgresql://asan_user:asan_pass@localhost:5432/asan_db

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- MinIO (S3-compatible object storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=asan-media
MINIO_SECURE=false

# --- CLIP model ---
CLIP_MODEL=openai/clip-vit-base-patch32
CLIP_SIMILARITY_THRESHOLD=0.75

# --- YOLO ---
YOLO_MODEL_PATH=yolov8n.pt

# --- Application ---
APP_ENV=development
SECRET_KEY=change-me-in-production
# API key required by institution-facing endpoints (X-Api-Key header)
API_KEY=institution-secret-key
